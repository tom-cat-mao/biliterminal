{
  "name": "biliterminal",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "doctor": "node tools/doctor.mjs",
    "doctor:full": "node tools/doctor.mjs --full",
    "legacy:python-baseline": "python3 -m unittest discover -s bili_terminal/tests -v",
    "dev": "tsx src/index.tsx",
    "build": "tsup src/index.tsx --format esm --target node20 --clean --sourcemap",
    "smoke": "node tools/smoke.mjs",
    "package:macos": "bash ./bili_terminal/build_macos_app.sh",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:core": "vitest run test/core",
    "test:storage": "vitest run test/storage",
    "test:api": "vitest run test/api",
    "test:cli": "vitest run test/cli",
    "test:tui": "vitest run test/tui",
    "ci": "pnpm run doctor && pnpm run typecheck && pnpm run test && pnpm run build && pnpm run smoke"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "got": "^14.6.5",
    "ink": "^6.8.0",
    "open": "^10.2.0",
    "react": "^19.1.1",
    "string-argv": "^0.3.2",
    "string-width": "^7.2.0",
    "tough-cookie": "^5.1.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "ink-testing-library": "^4.0.0",
    "nock": "^14.0.10",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.1"
  }
}
